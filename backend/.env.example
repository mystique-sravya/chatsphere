# ChatSphere Node backend environment variables

# Server port
PORT=8000

# Supabase PostgreSQL connection string (get from Supabase Dashboard → Settings → Database)
# Format: postgresql://postgres.<project-ref>:<password>@<host>:<port>/postgres
DATABASE_URL=postgresql://postgres.abcdef123456:MyStr0ngP@ssw0rd@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# JWT secret for auth tokens (generate with: openssl rand -hex 32)
JWT_SECRET=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

# Allowed frontend origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173

# Prefix for all database table names
TABLE_PREFIX=chatsphere

# Default DiceBear avatar style (see https://dicebear.com/styles)
DEFAULT_AVATAR_STYLE=lorelei-neutral

# SSL mode for database connection (verify-full | require | disable)
DB_SSL_MODE=verify-full

# Absolute path to Supabase root CA certificate (download from Supabase Dashboard → Settings → Database → SSL)
DB_SSL_ROOT_CERT_PATH=/Users/yourname/projects/chatsphere/backend/prod-ca-2021.crt

# How often to retry DB connection on failure (ms)
DB_RETRY_INTERVAL_MS=30000

# Users can delete their own messages within this window (hours)
MESSAGE_DELETE_WINDOW_HOURS=24

# Auto-delete messages older than this (days, for rooms with retention enabled)
MESSAGE_DELETE_AFTER_DAYS=7
